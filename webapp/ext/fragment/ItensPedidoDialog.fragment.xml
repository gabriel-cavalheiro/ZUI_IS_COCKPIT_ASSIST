<core:FragmentDefinition
  xmlns:core="sap.ui.core"
  xmlns="sap.m">

  <Dialog
    title="{i18n>itensPedidoTitle}"
    contentWidth="1100px"
    contentHeight="550px"
    draggable="true"
    resizable="true">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="{i18n>itensPedidoTitle}" level="H4" />
        </contentLeft>
        <contentMiddle>
          <Text text="Pedido: {dlgItensPedido>/pedido}" />
        </contentMiddle>
      </Bar>
    </customHeader>

    <content>
      <Table
        id="dlgTblItensPedido"
        items="{dlgItensPedido>/items}"
        noDataText="{i18n>semItensPedido}"
        growing="true"
        growingThreshold="50"
        fixedLayout="false">

        <columns>
          <Column width="8%">
            <Text text="{i18n>itemPedido}" />
          </Column>
          <Column width="12%">
            <Text text="{i18n>material}" />
          </Column>
          <Column width="22%">
            <Text text="{i18n>descricao}" />
          </Column>
          <Column width="8%" hAlign="Center">
            <Text text="{i18n>centro}" />
          </Column>
          <Column width="14%" hAlign="End">
            <Text text="{i18n>qtdItem}" />
          </Column>
          <Column width="14%" hAlign="End">
            <Text text="{i18n>valorLiquido}" />
          </Column>
          <Column width="10%" hAlign="Center">
            <Text text="{i18n>statusEntrega}" />
          </Column>
          <Column width="12%">
            <Text text="{i18n>textItem}" />
          </Column>
        </columns>

        <items>
          <ColumnListItem>
            <cells>
              <Text text="{dlgItensPedido>ItemPedido}" />
              <Text text="{dlgItensPedido>Material}" />
              <Text text="{dlgItensPedido>DescricaoMaterial}" />
              <Text text="{dlgItensPedido>Centro}" />
              <ObjectNumber
                number="{dlgItensPedido>Quantidade}"
                unit="{dlgItensPedido>UnidadeMedida}" />
              <ObjectNumber
                number="{dlgItensPedido>ValorLiquido}"
                unit="{dlgItensPedido>Moeda}"
                state="Information" />
              <Text text="{dlgItensPedido>StatusEntrega}" />
              <Text text="{dlgItensPedido>TextoItem}" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </content>

    <beginButton>
      <Button text="{i18n>fechar}" press=".onFecharItensPedidoDialog" />
    </beginButton>

  </Dialog>

</core:FragmentDefinition>
