<core:FragmentDefinition
  xmlns:core="sap.ui.core"
  xmlns="sap.m">

  <Dialog
    title="{i18n>titulosVencidosTitle}"
    contentWidth="1000px"
    contentHeight="550px"
    draggable="true"
    resizable="true">

    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="{i18n>titulosVencidosTitle}" level="H4" />
        </contentLeft>
        <contentMiddle>
          <Text text="Cliente: {dlgTitulos>/customerName}" />
        </contentMiddle>
        <contentRight>
          <ObjectNumber
            number="{dlgTitulos>/totalMontante}"
            unit="{dlgTitulos>/moeda}"
            state="Error"
            emphasized="true" />
        </contentRight>
      </Bar>
    </customHeader>

    <content>
      <Table
        id="dlgTblTitulos"
        items="{dlgTitulos>/items}"
        noDataText="{i18n>semTitulosVencidos}"
        growing="true"
        growingThreshold="50"
        fixedLayout="false">

        <columns>
          <Column width="14%">
            <Text text="{i18n>documentoContabil}" />
          </Column>
          <Column width="6%" hAlign="Center">
            <Text text="Item" />
          </Column>
          <Column width="8%" hAlign="Center">
            <Text text="{i18n>exercicioFiscal}" />
          </Column>
          <Column width="14%" hAlign="Center">
            <Text text="{i18n>prazoPagamento}" />
          </Column>
          <Column width="20%" hAlign="End">
            <Text text="{i18n>montante}" />
          </Column>
          <Column width="12%" hAlign="Center">
            <Text text="Status" />
          </Column>
        </columns>

        <items>
          <ColumnListItem
            highlight="{= ${dlgTitulos>StatusCriticality} === 1 ? 'Error' : ${dlgTitulos>StatusCriticality} === 2 ? 'Warning' : ${dlgTitulos>StatusCriticality} === 3 ? 'Success' : 'None' }">
            <cells>
              <Text text="{dlgTitulos>AccountingDocument}" />
              <Text text="{dlgTitulos>AccountingDocumentItem}" />
              <Text text="{dlgTitulos>FiscalYear}" />
              <Text text="{dlgTitulos>PrazoPagamento}" />
              <ObjectNumber
                number="{dlgTitulos>Montante}"
                unit="{dlgTitulos>Moeda}"
                state="{= ${dlgTitulos>StatusCriticality} === 1 ? 'Error' : ${dlgTitulos>StatusCriticality} === 2 ? 'Warning' : 'None' }" />
              <ObjectStatus
                text="{dlgTitulos>StatusDescricao}"
                state="{= ${dlgTitulos>StatusCriticality} === 1 ? 'Error' : ${dlgTitulos>StatusCriticality} === 2 ? 'Warning' : ${dlgTitulos>StatusCriticality} === 3 ? 'Success' : 'None' }" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </content>

    <beginButton>
      <Button text="{i18n>fechar}" press=".onFecharTitulosVencidosDialog" />
    </beginButton>

  </Dialog>

</core:FragmentDefinition>
